# ============================================
# NOX NETWORK - Environment Variables Template
# ============================================
# Copy this file to .env and fill in your real values
# NEVER commit .env with real secrets to git!

# Supabase configuration
SUPABASE_URL="https://your-project.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="your-supabase-service-role-key"

# Telegram configuration
TELEGRAM_BOT_TOKEN="your-telegram-bot-token"
VITE_BOT_USERNAME="your_bot_username"
COPYWRITER_BOT_TOKEN="your-copywriter-bot-token"
ADMIN_CHAT_ID="your-admin-chat-id"
NEWS_CHANNEL_ID="@your_channel"
ADMIN_TG_ID="your-admin-telegram-id"
VITE_ADMIN_TG_ID="your-admin-telegram-id"

# Payment and security (generate strong random strings)
JWT_SECRET="your-jwt-secret-min-32-chars"
CRON_SECRET="your-cron-secret-min-32-chars"
CRYPTO_PAY_TOKEN="your-crypto-pay-token"

# AI services
OPENROUTER_KEY="your-openrouter-api-key"
FAL_KEY="your-fal-api-key"
FAL_WEBHOOK_SECRET="your-fal-webhook-secret"

# Marzban VPN (optional)
MARZBAN_URL="https://panel.yourdomain.com"
MARZBAN_USERNAME="admin"
MARZBAN_PASSWORD="admin"

# Marzban VPN connection
MARZBAN_URL="https://panel.yourdomain.com"
MARZBAN_USERNAME="admin"
MARZBAN_PASSWORD="admin"
